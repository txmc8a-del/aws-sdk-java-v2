Outputs:
  # Output X - Load Balancer URL
  LoadBalancerURL:
    Description: URL of the Application Load Balancer
    Value: !Sub "http://${ApplicationLoadBalancer.DNSName}"
    Export:
      Name: !Sub "${AWS::StackName}-LoadBalancerURL"
  
  # Output Y - Auto Scaling Group Name
  AutoScalingGroupName:
    Description: Name of the Auto Scaling Group
    Value: !Ref WebServerGroup
    Export:
      Name: !Sub "${AWS::StackName}-ASGName"
  
  # Output Z - Target Group ARN
  TargetGroupARN:
    Description: ARN of the Target Group
    Value: !Ref WebServerTargetGroup
    Export:
      Name: !Sub "${AWS::StackName}-TargetGroupARN"
#Parameters:
  # Your registers A, B, C, D, E, F
  MinSize:
    Type: Number
    Default: 2
    Description: Minimum number of instances (Register A)
  
  MaxSize:
    Type: Number
    Default: 6
    Description: Maximum number of instances (Register B)
  
  InstanceType:
    Type: String
    Default: t3.micro
    Description: EC2 instance type (Register C)
  
  LatestAmiId:
    Type: AWS::SSM::Parameter::Value<AWS::EC2::Image::Id>
    Default: /aws/service/ami-amazon-linux-latest/amzn2-ami-hvm-x86_64-gp2
    Description: Latest Amazon Linux AMI (Register D)
  
  KeyPairName:
    Type: AWS::EC2::KeyPair::KeyName
    Description: EC2 Key Pair for SSH access (Register E)
  
  VPCID:
    Type: AWS::EC2::VPC::Id
    Description: VPC ID where resources will be created (Register F)
  
  PublicSubnets:
    Type: List<AWS::EC2::Subnet::Id>
    Description: Public subnets for ALB and Auto Scaling Group
# ALB Security Group (referenced but not defined)
ALBSecurityGroup:
  Type: AWS::EC2::SecurityGroup
  Properties:
    GroupDescription: Security group for Application Load Balancer
    VpcId: !Ref VPCID
    SecurityGroupIngress:
      - IpProtocol: tcp
        FromPort: 80
        ToPort: 80
        CidrIp: 0.0.0.0/0
      - IpProtocol: tcp
        FromPort: 443
        ToPort: 443
        CidrIp: 0.0.0.0/0

WebServerSecurityGroup: 
  Type: AWS::EC2::SecurityGroup
  Properties:
    GroupDescription: Security group for web servers
    VpcId: !Ref VPCID
    SecurityGroupIngress:
      - IpProtocol: tcp
        FromPort: 80
        ToPort: 80
        SourceSecurityGroupId: !Ref ALBSecurityGroup
